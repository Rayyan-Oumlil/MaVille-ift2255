# Variables d'environnement pour MaVille
# Copiez ce fichier en .env et modifiez les valeurs selon votre environnement

# Backend Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/maville
SPRING_DATASOURCE_USERNAME=maville_user
SPRING_DATASOURCE_PASSWORD=maville_password
SERVER_PORT=7000
SPRING_PROFILES_ACTIVE=production

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:7000/api
NEXT_PUBLIC_WS_URL=ws://localhost:7000/ws

# PostgreSQL Configuration (pour docker-compose)
POSTGRES_DB=maville
POSTGRES_USER=maville_user
POSTGRES_PASSWORD=maville_password

# API Externe Montréal
API_MONTREAL_URL=https://donnees.montreal.ca/api/3/action/datastore_search
API_MONTREAL_RESOURCE_ID=28708a5c-01ef-4f3a-9234-5ad04753e14a

# Sentry (optionnel)
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

